# 304 Game runtime config
NODE_ENV=production
PORT=4173

# Request / networking
TRUST_PROXY=false
REQUEST_TIMEOUT_MS=15000
MAX_JSON_BODY_BYTES=32768

# Optional origin policy (set a comma-separated list in production)
# When REQUIRE_ORIGIN_CHECK is true, requests with an Origin header must match host or ALLOWED_ORIGINS.
REQUIRE_ORIGIN_CHECK=true
ALLOWED_ORIGINS=

# Rate / presence lifecycles (milliseconds)
ROOM_PRESENCE_TIMEOUT_MS=120000
DISCONNECT_GRACE_MS=30000
ROOM_GC_AFTER_MS=3600000
SESSION_TTL_MS=86400000
CLEANUP_INTERVAL_MS=300000
MAX_SESSION_TOKEN_LEN=80

# In-memory capacity limits
MAX_SESSIONS_IN_MEMORY=5000
MAX_ROOMS_IN_MEMORY=1200

# Optional security tuning
# MAX_SESSION_TOKEN_LEN=80
